{
    "name": "ember-related-files",
    "displayName": "Ember Related Files",
    "description": "",
    "version": "1.5.0",
    "publisher": "josa",
    "license": "MIT",
    "homepage": "https://github.com/josa42/vscode-ember-related-files",
    "repository": {
        "type": "git",
        "url": "https://github.com/josa42/vscode-ember-related-files.git"
    },
    "bugs": {
        "url": "https://github.com/josa42/vscode-ember-related-files/issues"
    },
    "engines": {
        "vscode": "^1.20.0"
    },
    "categories": [
        "Other"
    ],
    "icon": "docs/assets/icon-128x128.png",
    "galleryBanner": {
        "color": "#FFFFFF",
        "theme": "light"
    },
    "activationEvents": [
        "onCommand:relatedFiles.relatedFiles"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "relatedFiles.relatedFiles",
                "title": "Related Files"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Ember Related Files",
            "properties": {
                "emberRelatedFiles.showQuickPickForSingleOption": {
                    "type": "boolean",
                    "default": false,
                    "description": "Show pick pick list event if only one option is available."
                },
                "emberRelatedFiles.enablePreview": {
                    "type": "boolean",
                    "default": true,
                    "description": "Preview editors are reused until they are kept."
                }
            }
        },
        "keybindings": [
            {
                "mac": "cmd+alt+r",
                "win": "ctrl+alt+r",
                "linux": "ctrl+alt+r",
                "key": "ctrl+alt+r",
                "command": "relatedFiles.relatedFiles"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "node esbuild.js",
        "test": "node ./node_modules/vscode/bin/test",
        "publish": "np --no-publish $* && vsce package && vsce publish"
    },
    "devDependencies": {
        "@types/mocha": "^5.2.5",
        "@types/node": "^10.7.1",
        "esbuild": "^0.28.0",
        "mocha": "~5.2.0",
        "typescript": "^6.0.3",
        "vscode": "^1.1.37"
    }
}
